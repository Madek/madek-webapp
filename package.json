{
  "name": "madek-webapp-ui",
  "description": "madek javascript toolchain",
  "private": true,
  "scripts": {
    "start": "bin/vite dev",
    "watch": "bin/vite dev",
    "build": "bin/vite build --clear && npm run -s build:ssr",
    "build:ssr": "vite build --config vite.config.ssr.ts",
    "build:ssr:dev": "NODE_ENV=development vite build --config vite.config.ssr.ts",
    "format": "prettier 'app/javascript/**/*.{js,jsx}' --write",
    "format:check": "prettier 'app/javascript/**/*.{js,jsx}' --check",
    "lint": "eslint 'app/javascript/**/*.{js,jsx}'",
    "lint:errors": "eslint --quiet 'app/javascript/**/*.{js,jsx}'",
    "lint:fix": "eslint --fix 'app/javascript/**/*.{js,jsx}'"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@eins78/typeahead.js": "0.11.2-pre.1",
    "@eins78/typopro-open-sans": "0.0.0",
    "active-lodash": "1.2.2",
    "ampersand-app": "2.0.0",
    "ampersand-model": "^8.0.1",
    "ampersand-rest-collection": "^6.0.0",
    "any_sha1": "0.1.1",
    "async": "^2.6.4",
    "babyparse": "0.4.6",
    "classnames": "2.2.5",
    "create-react-class": "^15.7.0",
    "font-awesome": "4.6.3",
    "hashblot": "0.4.5",
    "history": "2.1.2",
    "jquery": "^3.7.1",
    "linkify-string": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "local-links": "1.4.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "prop-types": "^15.6.1",
    "react": "^16.14.0",
    "react-bootstrap": "0.31.0",
    "react-day-picker": "^6.2.1",
    "react-dom": "^16.14.0",
    "react-file-drop": "^3.1.6",
    "react-waypoint": "^8.1.0",
    "tachyons": "^4.7.1",
    "uuid-validate": "0.0.2",
    "video.js": "5.16.0",
    "xhr": "2.4.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eins78/rspec-render-docs": "^1.0.0-alpha.4",
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.3.0",
    "sass-embedded": "^1.97.3",
    "vite": "^6.4.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-ruby": "^5.1.3"
  },
  "overrides": {
    "form-data": "^2.5.4",
    "minimist": "^1.2.6",
    "qs": "^6.14.1",
    "uglify-js": "^2.8.29",
    "semver": "^5.7.2",
    "minimatch": "^3.1.3",
    "static-eval": "^2.0.2"
  },
  "babel": {
    "plugins": [
      "@babel/plugin-transform-runtime"
    ],
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  },
  "author": "Max Albrecht <max.albrecht@zhdk.ch>",
  "repository": "https://github.com/Madek/madek-webapp.git",
  "licenses": [
    {
      "type": "GNU GPLv3",
      "url": "http://www.gnu.org/copyleft/gpl.html"
    }
  ]
}
