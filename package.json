{
  "name": "madek-webapp-ui",
  "description": "madek javascript toolchain",
  "private": true,
  "scripts": {
    "start": "npm run -s watch",
    "watch": "mkdir -p public/assets/bundles && npm run -s watch:app",
    "watch-all": "mkdir -p public/assets/bundles && npm run -s watch:app & npm run -s watch:server",
    "build": "mkdir -p public/assets/bundles && npm run -s build:app && npm run -s build:server",
    "watch:app": "mkdir -p public/assets/bundles && vite build --watch --config vite.config.client.mjs",
    "watch:app-embedded-view": "npm run -s watch:app",
    "watch:server": "mkdir -p public/assets/bundles && vite build --watch --config vite.config.server.mjs",
    "build:app": "mkdir -p public/assets/bundles && vite build --config vite.config.client.mjs",
    "build:app-embedded-view": "npm run -s build:app",
    "build:server": "mkdir -p public/assets/bundles && vite build --config vite.config.server.mjs",
    "build:integration": "npm run -s build:app",
    "build-devtools": "mkdir -p tmp && node --input-type=module --eval \"import {build} from 'esbuild'; build({entryPoints:['app/javascript/developer-tools.js'],bundle:true,platform:'browser',format:'iife',outfile:'tmp/devtools.js',loader:{'.js':'jsx','.jsx':'jsx'},jsxFactory:'React.createElement',jsxFragment:'React.Fragment',define:{'process.env.NODE_ENV':'\\\"production\\\"'},external:['crypto','fs','net'],minify:false})\"",
    "format": "prettier 'app/javascript/**/*.{js,jsx}' --write",
    "format:check": "prettier 'app/javascript/**/*.{js,jsx}' --check",
    "lint": "eslint 'app/javascript/**/*.{js,jsx}'",
    "lint:errors": "eslint --quiet 'app/javascript/**/*.{js,jsx}'",
    "lint:fix": "eslint --fix 'app/javascript/**/*.{js,jsx}'"
  },
  "dependencies": {
    "@eins78/typopro-open-sans": "0.0.0",
    "active-lodash": "1.2.2",
    "ampersand-app": "2.0.0",
    "ampersand-model": "^8.0.1",
    "ampersand-rest-collection": "^6.0.0",
    "any_sha1": "0.1.1",
    "async": "^2.6.4",
    "babyparse": "0.4.6",
    "bulk-require": "^1.0.1",
    "check-dependencies": "^2.0.0",
    "classnames": "2.2.5",
    "create-react-class": "^15.7.0",
    "downshift": "^9.3.2",
    "font-awesome": "4.6.3",
    "fs-extra": "3.0.1",
    "global": "4.3.2",
    "hashblot": "0.4.5",
    "history": "2.1.2",
    "linkify-string": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "local-links": "1.4.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "prop-types": "^15.6.1",
    "react": "^16.14.0",
    "react-bootstrap": "0.31.0",
    "react-day-picker": "^6.2.1",
    "react-dom": "^16.14.0",
    "react-file-drop": "^3.1.6",
    "react-waypoint": "^8.1.0",
    "tachyons": "^4.7.1",
    "url": "^0.11.4",
    "uuid-validate": "0.0.2",
    "video.js": "5.16.0",
    "xhr": "2.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-shorthand-properties": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@eins78/rspec-render-docs": "^1.0.0-alpha.4",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "fast-glob": "^3.3.3",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.3.0",
    "resolve": "^1.22.10",
    "vite": "^5.4.21"
  },
  "overrides": {
    "form-data": "^2.5.4",
    "minimist": "^1.2.6",
    "qs": "^6.14.1",
    "uglify-js": "^2.8.29",
    "semver": "^5.7.2",
    "minimatch": "^3.1.3",
    "static-eval": "^2.0.2"
  },
  "author": "Max Albrecht <max.albrecht@zhdk.ch>",
  "repository": "https://github.com/Madek/madek-webapp.git",
  "licenses": [
    {
      "type": "GNU GPLv3",
      "url": "http://www.gnu.org/copyleft/gpl.html"
    }
  ]
}
